# Database Connection URL (PostgreSQL in production, SQLite fallback is automated)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_interview_coach
PROJECT_NAME=AI Interview Coach Backend

# Primary Free-Token AI Provider (Groq API or local Ollama)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_your_free_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile

# ElevenLabs Voice API (Optional TTS)
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Allowed CORS Origins (comma-separated list)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
