# ==============================================================================
# AI INTERVIEW COACH • BACKEND ENVIRONMENT VARIABLES (.env)
# Copy this file to '.env' inside the /backend directory or add these exact keys
# under your Cloud Deployment dashboard (Render, Railway, Heroku, Fly.io).
# ==============================================================================

# 1. PYTHON RUNTIME (Recommended for Cloud Deployments like Render / Railway)
PYTHON_VERSION=3.11.9

# 2. APPLICATION & DATABASE CONFIGURATION
PROJECT_NAME="AI Interview Coach Backend"
# In cloud production (Render/Railway), insert your managed PostgreSQL connection string here:
# DATABASE_URL=postgresql://user:password@hostname:5432/dbname
# For local or single-instance cloud deployment, SQLite works automatically with zero config:
DATABASE_URL=sqlite:///./ai_interview_coach.db

# 3. CORS ALLOWED ORIGINS (Comma-separated list of allowed frontend URLs)
# Add your live Vercel/Netlify frontend URL here when deploying (e.g., https://your-frontend-app.vercel.app)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173,https://your-frontend-app.vercel.app

# ==============================================================================
# AI / LLM CONFIGURATION (Triple-Tier Cascading Failover)
# You can configure either OpenRouter, Groq, or both. If any key runs out of quota,
# the backend automatically cascades to the next tier or to offline high-fidelity benchmarks.
# ==============================================================================

# Tier 1: Primary Custom Endpoint (Groq Free Cloud or local Ollama)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_your_free_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile

# Tier 2: Backup OpenRouter Endpoint
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# ==============================================================================
# VOICE SYNTHESIS / TTS CONFIGURATION (Optional - falls back to Browser HD Voice)
# ==============================================================================
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Default professional female voice ("Rachel"): 21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
